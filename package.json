{
  "name": "tokentoilet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap": "pnpm install --prefer-offline --loglevel warn",
    "build": "next build",
    "build-storybook": "storybook build",
    "dev": "next dev",
    "fix": "eslint --fix",
    "lint": "eslint",
    "prepare": "simple-git-hooks",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run",
    "test:bench": "vitest bench",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "validate": "pnpm run lint && pnpm run type-check && pnpm run test && pnpm run validate:design-system && pnpm run build-storybook",
    "validate:bundle-size": "NEXT_BUILD_ENV_ANALYZE=true pnpm run build",
    "validate:design-system": "tsx scripts/validate-design-system.ts",
    "validate:stories": "pnpm run build-storybook",
    "validate:web3": "tsx scripts/validate-web3-integration.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,js,jsx,tsx,css,md,json,toml,yaml,yml}": [
      "eslint --fix"
    ]
  },
  "prettier": "@bfra.me/prettier-config/120-proof",
  "dependencies": {
    "@reown/appkit": "^1.7.18",
    "@reown/appkit-adapter-wagmi": "^1.7.18",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-virtual": "^3.13.12",
    "consola": "^3.4.2",
    "crypto-js": "^4.2.0",
    "lru-cache": "^11.2.4",
    "lucide-react": "^0.577.0",
    "next": "16.2.4",
    "next-themes": "^0.4.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hot-toast": "^2.6.0",
    "std-env": "^4.0.0",
    "wagmi": "^2.14.11",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@bfra.me/eslint-config": "^0.50.0",
    "@bfra.me/prettier-config": "^0.16.0",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@next/bundle-analyzer": "^16.0.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@storybook/addon-essentials": "9.0.0-alpha.12",
    "@storybook/addon-interactions": "9.0.0-alpha.10",
    "@storybook/addon-links": "^10.0.0",
    "@storybook/addon-themes": "^10.0.0",
    "@storybook/blocks": "9.0.0-alpha.17",
    "@storybook/nextjs": "^10.0.0",
    "@storybook/react": "^10.0.0",
    "@storybook/test": "9.0.0-alpha.2",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.0.7",
    "@vitest/ui": "^4.0.7",
    "autoprefixer": "10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.0.0",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.1.5",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.0.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "4.2.4",
    "tsx": "^4.20.5",
    "typescript": "6.0.3",
    "viem": "^2.23.0",
    "vite": "^8.0.8",
    "vitest": "^4.0.7",
    "vitest-axe": "^0.1.0"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "@metamask/sdk-communication-layer@>=0.16.0 <=0.33.0": ">=0.33.1",
      "@metamask/sdk@>=0.16.0 <=0.33.0": ">=0.33.1",
      "axios": "^1.15.0",
      "bn.js@<4.12.3": ">=4.12.3",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "flatted@<=3.4.1": ">=3.4.2",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "hono@<4.12.14": ">=4.12.14",
      "js-yaml@<4.1.1": ">=4.1.1",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "next@>=16.0.0-beta.0 <16.2.3": ">=16.2.3",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "postcss": ">=8.5.10",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "socket.io-parser@>=4.0.0 <4.2.6": ">=4.2.6",
      "storybook@>=10.0.0-beta.0 <10.2.10": ">=10.2.10",
      "vite@>=7.1.0 <=7.1.10": ">=7.1.11",
      "vite@>=8.0.0 <=8.0.4": ">=8.0.5",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  }
}
